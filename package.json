{
  "name": "satsure-autocomplete-assignment",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Risk-based UI and API automation for the SatSure autocomplete form practical assignment.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --project=ui-chromium --headed",
    "test:debug": "playwright test --project=ui-chromium --debug",
    "report": "playwright show-report",
    "serve:mock": "node scripts/mock-server.cjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "bcp-47": "^2.1.1",
    "typescript": "^6.0.0"
  }
}
